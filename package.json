{
  "name": "js-rich-body-highlighter",
  "version": "0.1.1",
  "description": "Premium, framework-agnostic muscle map. Highlights muscles with mix-blend-mode over a detailed body illustration for a rich, 3D look instead of flat polygon fills.",
  "type": "module",
  "license": "MIT",
  "author": "crmapache",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crmapache/js-rich-body-highlighter.git"
  },
  "bugs": {
    "url": "https://github.com/crmapache/js-rich-body-highlighter/issues"
  },
  "homepage": "https://js-rich-body-highlighter.vercel.app",
  "keywords": [
    "muscle",
    "anatomy",
    "body",
    "highlighter",
    "muscle-map",
    "svg",
    "fitness",
    "blend-mode",
    "react",
    "vue",
    "svelte",
    "angular",
    "web-component",
    "custom-element"
  ],
  "sideEffects": [
    "**/web-component/**"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react/index.d.ts"
      ],
      "vue": [
        "./dist/vue/index.d.ts"
      ],
      "svelte": [
        "./dist/svelte/index.d.ts"
      ],
      "web-component": [
        "./dist/web-component/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "import": "./dist/svelte/index.js"
    },
    "./web-component": {
      "types": "./dist/web-component/index.d.ts",
      "import": "./dist/web-component/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --config vite.demo.config.ts",
    "dev:e2e": "vite --config e2e/vite.config.ts",
    "build": "tsup",
    "build:demo": "vite build --config vite.demo.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.playground.json",
    "convert:bodies": "node scripts/convert-bodies.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.2",
    "svelte": "^5.56.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vue": "^3.5.39"
  }
}
